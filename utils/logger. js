const pino = require('pino')
const config = require('../config')

// ─────────────────────────────────────────
//         AKAZA BOT — CUSTOM LOGGER
// ─────────────────────────────────────────

const logger = pino(
  {
    level: config.debug ? 'debug' : 'info',
    base: null, // removes pid and hostname from logs
    timestamp: pino.stdTimeFunctions.isoTime,
  },
  pino.transport({
    target: 'pino-pretty',
    options: {
      colorize: true,
      translateTime: 'SYS:HH:MM:ss',
      ignore: 'pid,hostname',
      messageFormat: `[${config.botName}] {msg}`,
    },
  })
)

// Convenience wrappers
const log = {
  info: (msg) => logger.info(msg),
  warn: (msg) => logger.warn(msg),
  error: (msg) => logger.error(msg),
  debug: (msg) => logger.debug(msg),
  success: (msg) => logger.info(`✅ ${msg}`),
  command: (sender, cmd) => logger.info(`⚡ Command [${cmd}] triggered by ${sender}`),
  connection: (msg) => logger.info(`🔗 ${msg}`),
}

module.exports = log

